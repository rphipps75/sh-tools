{
    // Version of the setting file.  Always 0.2
    "version": "0.2",
    // language - current active spelling language
    "language": "en-GB",
    // words - list of words to be always considered correct
    "words": [
        "contrib",
        "flavor",
        "gsub",
        "milli",
        "newgrp",
        "teardown",
        "venv"
    ],
    "ignorePaths": [
        ".git",
        ".local/*",
        ".vscode/*",
        ".editorconfig",
        ".gitattributes",
        ".gitignore",
        ".cspell.json"
    ]
}
