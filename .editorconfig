# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = false
tab_width = 4
trim_trailing_whitespace = false

[.editorconfig]
trim_trailing_whitespace = true

[.gitignore]
trim_trailing_whitespace = true

[{Dockerfile,Dockerfile.prod,Dockerfile.dev,Dockerfile.template}]
indent_style = space
indent_size = 4

[*.json]
trim_trailing_whitespace = true

[*.md]
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = false

[*.sh]
indent_size = 2
tab_width = 2
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
